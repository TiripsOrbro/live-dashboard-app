DATABASE_URL=your_database_url

# ── Macromatix (sales / labour scheduler grid) — tacobellau.macromatix.net ──
SCRAPER_USERNAME=tba158258
SCRAPER_PASSWORD=taco158258

SCRAPER_TARGET_URL=target_website_url
# Scheduled orders scrape: date = today + N days (0 = today). Default in code is 2 if unset.
# SCRAPER_SCHEDULED_ORDERS_DAY_OFFSET=2
# Headless Chromium for Macromatix (default). Set SCRAPER_HEADLESS=false to watch the browser when debugging.
SCRAPER_HEADLESS=true
# Optional: SCRAPER_SLOW_MO_MS=75
# Optional: SCRAPER_DEVTOOLS=1
# After picking date: ASP.NET postback reloads the grid (default on). Set false if navigation hangs.
# SCRAPER_SCHEDULED_DATE_POSTBACK=false
# Max ms to wait for scheduled-orders grid after date postback (partial postback = no full navigation).
# SCRAPER_SCHEDULED_ORDERS_SETTLE_MS=4500
SESSION_SECRET=your_session_secret
