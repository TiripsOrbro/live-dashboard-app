# Copy to `.env` on the Pi and your dev PC (one file for both).
# chmod 600 .env

# ── Store portal logins (MMX, LifeLenz, SMG, NSF) ──
# Per-store encrypted credentials — configure in Admin menu → Setup Store Logins.
STORE_CREDENTIALS_KEY=change-this-long-random-secret

# Pi only — path to Chromium (auto-detected if omitted)
# SCRAPER_EXECUTABLE_PATH=/usr/bin/chromium

SCRAPER_HEADLESS=true
# Forecast tool only — set false to watch Macromatix while submitting (does not affect sales scrape)
FORECAST_SCRAPER_HEADLESS=false
# Pi 4 (4GB): use 2. Dev / 8GB+: 3–4. Set 1 for fully sequential scrapes.
SCRAPER_CONCURRENCY=2
SCRAPER_BLOCK_RESOURCES=true

# Sales scrape interval — full market every N seconds during store active hours (default 120 = 2 min)
SCRAPE_FAST_INTERVAL_SECONDS=120
# Re-fetch Macromatix forecast row after this many seconds (actual sales still update every scrape)
# FORECAST_CACHE_SECONDS=3600
# Legacy (unused): presence tracking TTL if re-enabled later
# SCRAPE_PRESENCE_TTL_SECONDS=180

# Long scrape runs (~20 stores). Increase if workers time out.
# SCRAPE_TIMEOUT_MS=900000

# ── Dashboard ──
DASHBOARD_TIME_ZONE=Australia/Melbourne
# Required for stable sign-in across PM2 restarts (generate a long random string).
# Without this, the app uses users/data/.dashboard-auth-secret on the Pi.
# DASHBOARD_AUTH_SECRET=change-this-long-random-string

# Pi 4 (4GB): PM2 dashboard memory cap (default 900M in ecosystem.config.cjs). Optional: 1G
# PM2_DASHBOARD_MAX_MEMORY=900M
# Log RSS + tracked browser count every 30 min (pm2 logs dashboard)
# DASHBOARD_MEMORY_LOG=1

# Forecast scheduler (PM2 forecast-scheduler process). Admin toggle must also be enabled in Forecast tool.
# FORECAST_SCHEDULE_ENABLED=1
# FORECAST_SCHEDULE_HOUR=5
# FORECAST_SCHEDULE_WINDOW_MIN=30
# FORECAST_HISTORY_DAYS=35
# Hot window for forecast math and live capture (default 35 = 5 weeks).
# FORECAST_HISTORY_ARCHIVE_DAYS=182
# Longer browse/retention window; older days move to a compact archive (no raw MMX grid).

# Dev-only LifeLenz login for probe scripts (remove on Pi)
# TempLifeLenzU=your-lifelenz-email
# TempLifeLenzP=your-lifelenz-password
# LIFELENZ_SCRAPER_HEADLESS=false

# ── Domain path overrides (optional — defaults use domain folders) ──
# PROJECT_ROOT=/path/to/live-dashboard-app
# STORELIST_PATH=stores/.storelist
# USERS_ACCOUNTS_DIR=users/accounts
# VENDOR_CATALOGS_DIR=vendors/catalogs
# VENDOR_REPORTS_DIR=vendors/reports

# ── Optional ──
# DASHBOARD_NOLOGIN_ENABLED=1
# DASHBOARD_NOLOGIN_STORES=3811
# DASHBOARD_NOLOGIN_SECRET=change-this-long-random-string
# DASHBOARD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
