# Do not download Puppeteer's bundled Chromium on install.
# The scraper uses the system Chromium (see SCRAPER_EXECUTABLE_PATH / resolveChromiumExecutablePath),
# and Puppeteer 10's bundled revision has no ARM64 build, so the download fails on a Raspberry Pi.
# (npm may warn this key is "unknown" — that is cosmetic; Puppeteer's install script still reads it.)
puppeteer_skip_chromium_download=true
