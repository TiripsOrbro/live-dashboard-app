    "headerHtmlSnippet": "\n        <!-- ngIf: IsSalesItems && !Vm.SalesItem && GetSalesItems().SalesItems.length -->\n\n        <!-- ngIf: !IsSalesItems || Vm.SalesItem || Vm.NotHasForecastForSalesItem --><div ng-if=\"!IsSalesItems || Vm.SalesItem || Vm.NotHasForecastForSalesItem\" class=\"ng-scope\">\n            <!-- ngIf: !Vm.HasForecast && !Vm.Loading -->\n            <!-- ngIf: Vm.HasForecast && !Vm.HasData && !Vm.Loading -->\n        </div><!-- end ngIf: !IsSalesItems || Vm.SalesItem || Vm.NotHasForecastForSalesItem -->\n\n        <div ng-show=\"Vm.HasData  &amp;&amp; !Vm.Loading\" class=\"fill-height\">\n            <!-- ngIf: ShowSelectEditableFilterWarning() -->\n\n            <div class=\"fill-height ng-isolate-scope\" ng-click=\"OnClick($event)\" options=\"GetForecastingOptions()\" forecastobject=\"GetForecastObject()\">\n    <div class=\"mx-grid fill-height\">\n        <!-- ngIf: (Options || ForecastingOptions).Part !== null -->\n        <div class=\"mx-grid-header-container\" style=\"height: 54px;\">\n            <div id=\"ForecastGridHeader\" class=\"mx-grid-header mx-grid-header-no-sort\" style=\"visibility: visible; height: 54px;\">\n                <div class=\"mx-grid-column-header no-border-right\" style=\"width: 36.1094px; left: 0px; height: 54px;\">&nbsp;</div>\n                <div class=\"mx-grid-column-header\" style=\"width: 328.047px; left: 36.1094px; height: 54px;\">\n                    <span class=\"mx-grid-column-header-title ng-binding\">\n                        Time\n                    </span>\n                </div>\n                <!-- ngIf: Options.MetricKey !== 'events' --><div class=\"mx-grid-column-header ng-scope\" ng-if=\"Options.MetricKey !== 'events'\" style=\"width: 218.703px; left: 364.156px; height: 54px;\">\n                    <span class=\"mx-grid-column-header-title ng-binding\">Last Year</span>\n                </div><!-- end ngIf: Options.MetricKey !== 'events' -->\n                <!-- ngIf: Options.MetricKey !== 'events' && CanViewCateringValues -->\n                <!-- ngIf: Options.MetricKey !== 'events' --><div class=\"mx-grid-column-header ng-scope\" ng-if=\"Options.MetricKey !== 'events'\" style=\"width: 218.703px; left: 582.859px; height: 54px;\">\n                    <span class=\"mx-grid-column-header-title ng-binding\">System Forecast</span>\n                </div><!-- end ngIf: Options.MetricKey !== 'events' -->\n                <div class=\"mx-grid-column-header\" style=\"width: 437.438px; left: 801.562px; height: 54px;\">\n                    <!-- ngIf: Options.MetricKey === 'events' -->\n                    <!-- ngIf: Options.MetricKey !== 'events' --><span class=\"mx-grid-column-header-title ng-binding ng-scope\" ng-if=\"Options.MetricKey !== 'events'\">Manager Forecast</span><!-- end ngIf: Options.MetricKey !== 'events' -->\n                    <!-- ngIf: Options.MetricKey !== 'events' --><span ng-if=\"Options.MetricKey !== 'events'\" class=\"btn-group mx-btn-toggle text-nowrap ng-scope\">\n                        <!-- ngIf: Options.MetricKey === 'sales' --><button ng-if=\"Options.MetricKey === 'sales'\" class=\"btn mx-panel-button ng-binding ng-scope btn-success\" ng-class=\"{ 'btn-success': !InlineOptions.IsByPercentage, 'btn-secondary': InlineOptions.IsByPercentage }\" ng-click=\"OnClickSetByPercentage(false, $event)\">$</button><!-- end ngIf: Options.MetricKey === 'sales' -->\n                        <!-- ngIf: Options.MetricKey === 'transactions' -->\n                        <button type=\"button\" class=\"btn mx-panel-button btn-secondary\" ng-class=\"{ 'btn-success': InlineOptions.IsByPercentage, 'btn-secondary': !InlineOptions.IsByPercentage }\" ng-click=\"OnClickSetByPercentage(true, $event)\">%</button>\n                    </span><!-- end ngIf: Options.MetricKey !== 'events' -->\n                </div>\n            </div>\n        </div>\n        <div class=\"mx-grid-body-container touch-scrollable\" style=\"top: 54px;\">\n            <table class=\"mx-grid-body forecastGrid ng-isolate-scope\" mx-scrollable-table=\"\" watch=\"GridView.IntervalStarts\" header-id=\"ForecastGridHeader\">\n                <tbody>\n                    <!-- ngIf: GridView --><tr class=\"mx-grid-row mx-grid-summary-row ng-scope\" ng-if=\"GridView\" row-index=\"0\" ng-class=\"{ 'mx-fg-editing': 0 === EditingIndex}\">\n                        <td class=\"mx-grid-column mx-grid-column-min-width no-border-right\">&nbsp;</td>\n                        <td class=\"mx-grid-column col-sm-3 no-padding-left-important ng-binding\">Day Totals</td>\n\n                        <!-- ngIf: Options.MetricKey === 'sales' --><td class=\"mx-grid-column col-sm-2 text-right ng-binding ng-scope\" ng-if=\"Options.MetricKey === 'sales'\" id=\"mx-forecast-grid-Sales-directive-list-daytotal-lastyear\">$5,377.89</td><!-- end ngIf: Options.MetricKey === 'sales' -->\n                        <!-- ngIf: Options.MetricKey === 'transactions' -->\n                        \n                        <!-- ngIf: Options.MetricKey === 'sales' && CanViewCateringValues -->\n                        <!-- ngIf: Options.MetricKey === 'transactions' && CanViewCateringValues -->\n\n                        <!-- ngIf: Options.MetricKey === 'sales' --><td class=\"mx-grid-column col-sm-2 text-right ng-binding ng-scope\" ng-if=\"Options.MetricKey === 'sales'\" id=\"mx-forecast-grid-Sales-directive-list-daytotal-systemsales\">$7,009.00</td><!-- end ngIf: Options.MetricKey === 'sales' -->\n                        <!-- ngIf: Options.MetricKey === 'transactions' -->\n\n                        <td class=\"mx-grid-column mx-grid-column-input col-sm-4\" ng-class=\"{ 'col-sm-4': !CanViewCateringValues, 'col-sm-3': CanViewCateringValues }\">\n                            <span class=\"form-control\" ng-disabled=\"ForecastObject.IsLocked || CellNotEditable(0)\" ng-class=\"{'mx-fg-isdisabled': ForecastObject.IsLocked || CellNotEditable(0), 'mx-fg-novalue': CellValue(0) === undefined}\">\n       